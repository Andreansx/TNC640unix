# Copy to  config.env  (gitignored) to override defaults without editing scripts.
# All values are optional.

# VM name as registered in VirtualBox
# VM=TNC640

# Path to your unpacked HEIDENHAIN download (the folder containing the OVA and
# prog/setup.zip). If unset, ./tnc640 searches ./34059518* and the repo root.
# PACKAGE=/home/you/Downloads/TNC640_340595_18_SP4

# VM resources (HEIDENHAIN requires at least 1536 MiB)
# CPUS=2
# MEMORY=3072
# VRAM=64

# Host port forwarded to guest:22 (optional SSH convenience)
# SSH_PORT=2222

# Force a specific VBoxManage binary
# VBOXMANAGE=/usr/bin/VBoxManage
